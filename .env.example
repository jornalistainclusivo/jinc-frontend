# ==============================================================================
# INTELIGÊNCIA ARTIFICIAL (Multi-Provider)
# ==============================================================================
# Altere AI_PROVIDER para definir o provedor de Visão/Texto do Frontend
# O TTS (Text-to-Speech) continuará usando GEMINI exclusivamente
AI_PROVIDER="gemini"

# Provider: Google Gemini
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Provider: Groq Cloud (rápido, OpenAI-compatible)
# GROQ_API_KEY="COLE_AQUI"
# GROQ_VISION_MODEL="llama-3.2-11b-vision-preview"

# Provider: OpenRouter (Gateway multi-modelo)
# OPENROUTER_API_KEY="COLE_AQUI"
# OPENROUTER_VISION_MODEL="anthropic/claude-3-haiku"

# Provider: Ollama Local (Offline)
# OLLAMA_BASE_URL="http://127.0.0.1:11434"
# OLLAMA_VISION_MODEL="llava"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
